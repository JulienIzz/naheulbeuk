{
  "name": "naheulbeuk",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:staging": "STAGE=staging expo start",
    "start:production": "STAGE=production expo start",
    "prebuild": "STAGE=dev expo prebuild",
    "prebuild:staging": "STAGE=staging expo prebuild",
    "prebuild:production": "STAGE=production expo prebuild",
    "build:production:android": "./scripts/buildProduction.sh android",
    "build:production:ios": "./scripts/buildProduction.sh ios",
    "build:production": "./scripts/buildProduction.sh all",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test:unit": "jest",
    "test:lint": "eslint .",
    "test:types": "tsc --noEmit",
    "test": "./scripts/checkTranslation.sh && yarn test:unit && yarn test:lint && yarn test:types",
    "test:claude": "jest --onlyChanged --bail && eslint . --fix --ext .js,.jsx,.ts,.tsx --report-unused-disable-directives --max-warnings 0 --cache --cache-strategy content --cache-location .cache/eslint.json && yarn test:types",
    "find-dead-code": "ts-prune --ignore '__mocks__/*|src/testing/*|metro.config.js|.*.d.ts'",
    "translations:extract": "lingui extract --clean",
    "translations:compile": "lingui compile",
    "translations:update": "lingui extract --clean && lingui compile",
    "postinstall": "yarn translations:update"
  },
  "dependencies": {
    "@emotion/native": "^11.11.0",
    "@emotion/react": "^11.14.0",
    "@expo-google-fonts/alegreya": "^0.4.1",
    "@formatjs/intl-listformat": "^7.7.10",
    "@formatjs/intl-locale": "^4.2.10",
    "@lingui/core": "^5.9.2",
    "@lingui/react": "^5.9.2",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "expo": "55",
    "expo-application": "~55.0.8",
    "expo-asset": "~55.0.8",
    "expo-audio": "~55.0.6",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.13",
    "expo-font": "^55.0.4",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.8",
    "expo-router": "~55.0.4",
    "expo-splash-screen": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-error-boundary": "^6.1.1",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bam.tech/eslint-plugin": "^8.0.0",
    "@lingui/cli": "^5.9.2",
    "@lingui/macro": "^5.9.2",
    "@sucrase/jest-plugin": "^3.0.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/babel-plugin-macros": "^3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "@types/react-dom": "~19.1.7",
    "@types/react-test-renderer": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "babel-plugin-macros": "^3.1.0",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-define-config": "^2.1.0",
    "eslint-import-resolver-typescript": "^3.8.7",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-jest-formatting": "^3.1.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-testing-library": "^6.5.0",
    "eslint-plugin-unused-imports": "^3.2.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "jest-fail-on-console": "^3.3.1",
    "jest-watch-typeahead": "^2.2.2",
    "prettier": "^3.5.3",
    "react-test-renderer": "19.2.0",
    "sucrase": "^3.35.0",
    "ts-node": "^10.9.2",
    "ts-prune": "^0.10.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.46.2"
  },
  "private": true,
  "packageManager": "yarn@4.3.1",
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  }
}
